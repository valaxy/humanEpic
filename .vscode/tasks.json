{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Godot: 主动触发资源刷新",
            "type": "shell",
            "command": ".\\bin\\Godot_v4.6.1-stable_mono_win64.exe",
            "args": [
                "--editor",
                "--headless",
                "--quit"
            ],
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "测试: GdUnit4 运行并生成报告",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                ".\\scripts\\run-gdunit-tests.ps1"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "测试: 一键刷新并运行 GdUnit4",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Godot: 主动触发资源刷新",
                "测试: GdUnit4 运行并生成报告"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "打开Godot编辑器",
            "type": "shell",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "command": ".\\bin\\Godot_v4.6.1-stable_mono_win64.exe --editor"
        }
    ]
}